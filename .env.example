# =============================================================================
# D&D Adventure Bot — environment file
# =============================================================================
# 1) Run:  pnpm run env:init     (creates .env from this file if missing)
# 2) Open the new .env file in this folder (project root).
# 3) Replace ONLY the placeholder values below with your real secrets.
#    Do not commit .env — it is gitignored. Safe to sell: ship .env.example only.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — paste your full connection string (from Neon, Supabase, local, etc.)
# Example shape: postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME
# -----------------------------------------------------------------------------
DATABASE_URL=PASTE_YOUR_POSTGRES_CONNECTION_STRING_HERE

# -----------------------------------------------------------------------------
# OpenAI — for self-hosted / local dev (Replit sets these automatically in Secrets)
# -----------------------------------------------------------------------------
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=PASTE_YOUR_OPENAI_SECRET_KEY_HERE

# -----------------------------------------------------------------------------
# Optional — purchase license (soft check: production logs a reminder if unset)
# -----------------------------------------------------------------------------
# LICENSE_KEY=

# -----------------------------------------------------------------------------
# Optional (usually leave commented)
# -----------------------------------------------------------------------------
# PORT=3000
# NODE_ENV=development
# BASE_PATH=/
# REPL_ID=
